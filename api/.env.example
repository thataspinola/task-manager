NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_manager?schema=public"
# Comma-separated origins, or * / empty for reflect all (dev)
CORS_ORIGIN=http://localhost:5173

# --- Sentry (https://sentry.io → Create Project → Node.js → copie o DSN) ---
# Ex.: SENTRY_DSN=https://abc123@o0.ingest.sentry.io/4500000000000000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
