# Copie para `.env` na raiz:  cp .env.example .env
# Usado por: npm run sonar:api | sonar:bff | sonar:all  (não commitar o .env)

# --- SonarQube local ---
# 1) npm run obs:up  →  http://localhost:9000
# 2) Login admin / admin (troque a senha)
# 3) Avatar → My Account → Security → Generate Tokens → "local"
# 4) Cole o token abaixo
SONAR_HOST_URL=http://host.docker.internal:9000
SONAR_TOKEN=
