{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"eslint.config.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"eslint.config.js\"",
    "lint": "eslint .",
    "preview": "vite preview --port 4173",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit",
    "sonar:scan": "node ../scripts/sonar-scan.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
